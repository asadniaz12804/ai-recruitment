# ============================================================
# Server environment variables
# Copy this file to .env and fill in the values.
# ============================================================

# ---------- General ----------
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# ---------- Database ----------
# Local: mongodb://localhost:27017/ai_recruitment
# Atlas: mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/ai_recruitment?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/ai_recruitment

# ---------- Redis (BullMQ) ----------
# Local: redis://localhost:6379
# Upstash: rediss://default:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379

# ---------- CORS ----------
# Comma-separated list of allowed origins (frontend URL)
CORS_ORIGIN=http://localhost:5173

# ---------- JWT ----------
JWT_ACCESS_SECRET=change-me-to-a-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ---------- Cookies ----------
# In production with separate domains, set COOKIE_SAMESITE=none
COOKIE_SECURE=false
COOKIE_SAMESITE=
COOKIE_DOMAIN=

# ---------- AI ----------
AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---------- Cloudinary (resume uploads) ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- Upload limits ----------
MAX_RESUME_SIZE_MB=10
